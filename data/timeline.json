    {
      "id": "paleo-indians",
      "type": "history",
      "date": "~13,000 years ago",
      "body": "First people (Paleoindians) move into Maine after the Laurentide ice sheet retreats. Tundra and open spruce parkland environment, similar to Labrador today. The shoreline of the time is now ~200 feet underwater.",
      "link": "https://en.wikipedia.org/wiki/Paleo-Indians",
      "image": "/timeline-images/paleo-indians.jpg"
